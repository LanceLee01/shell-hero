{
  "name": "roguelike-game",
  "private": true,
  "description": "2D Roguelite shooter game",
  "author": "opencode",
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron . --dev",
    "electron:build": "vite build && electron-builder --win portable",
    "pack": "vite build && electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.roguelike.game",
    "productName": "弹壳勇士",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-v${version}-${arch}.${ext}"
    },
    "extraMetadata": {
      "main": "electron/main.cjs"
    }
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
